{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "customManagers:dockerfileVersions"
  ],
  "enabledManagers": [
    "dockerfile",
    "custom.regex"
  ],
  "customManagers": [
      {
      "customType": "regex",
      "managerFilePatterns": [
        "Dockerfile"
      ],
      "matchStrings": [
        "https://github.com/(?<packageName>.*?)/archive/refs/tags/(?<currentValue>.*?)(.tar.gz|.zip)"
      ],
      "datasourceTemplate": "github-tags"
    }
  ]
}
