{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:best-practices",
    "customManagers:dockerfileVersions"
  ],
  "enabledManagers": [
    "dockerfile",
    "custom.regex"
  ],
  "packageRules": [
    {
      "matchPackageNames": ["homeassistant"],
      "allowedVersions": "!/[a-z]$/"
    }
  ],
  "customManagers": [
      {
      "customType": "regex",
      "managerFilePatterns": [
        "Dockerfile"
      ],
      "matchStrings": [
        "https://github.com/(?<packageName>.*?)(/archive/refs/tags/|/releases/download/)(?<currentValue>v?[0-9]*\\.[0-9]*\\.[0-9]*)"
      ],
      "datasourceTemplate": "github-tags"
    }
  ]
}
